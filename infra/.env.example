# ─────────────────────────────────────────────────────────────────────
# Superset MCP Agent — deployment configuration
# Copy to `.env` (cp .env.example .env) and fill in the secrets.
# The app loads these via python-dotenv; docker-compose injects them too.
# ─────────────────────────────────────────────────────────────────────

# ── REQUIRED secrets ─────────────────────────────────────────────────
# OpenAI API key used by the LLM client (chat-completions)
OPENAI_API_KEY=sk-REPLACE_ME

# Bearer token for the hosted Superset MCP service
MCP_AUTH_TOKEN=REPLACE_WITH_MCP_JWT

# Superset login (the pipeline health check authenticates against Superset)
SUPERSET_BASE_URL=https://dashboard.idx-ng.com
SUPERSET_USERNAME=admin
SUPERSET_PASSWORD=REPLACE_ME

# ── Web UI ───────────────────────────────────────────────────────────
# Sub-path the UI is served under behind the reverse proxy. For
# https://dashboard.idx-ng.com/chatbot set this to /chatbot. Empty = root.
APP_BASE_PATH=/chatbot

# ── MCP service ──────────────────────────────────────────────────────
MCP_URL=https://dashboard.idx-ng.com/mcp

# ── LLM ──────────────────────────────────────────────────────────────
LLM_MODEL=gpt-5.5

# ── Keycloak (web UI auth) ───────────────────────────────────────────
# Defaults match the shared ui-cbn client. The app's public origin MUST be
# registered in this client's Valid Redirect URIs + Web Origins in Keycloak.
KEYCLOAK_ENABLED=true
KEYCLOAK_URL=https://keycloak.idx-ng.com/auth
KEYCLOAK_REALM=cbn
KEYCLOAK_CLIENT_ID=angular-client
# Optional: restrict access to holders of a specific realm role (empty = any authenticated user)
KEYCLOAK_REQUIRED_ROLE=
